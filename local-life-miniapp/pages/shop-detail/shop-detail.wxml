<view class="page">
  <view class="hero">
    <text class="h-name">{{shopName||'加载中...'}}</text>
    <text class="h-meta">⭐{{shop.score||'-'}} · 人均¥{{(shop.avgPrice/100)||'-'}} · 🕐{{shop.openHours||'-'}}</text>
    <text class="h-meta">📍 {{shop.address||'-'}} · 距您{{shop.distance||'-'}}km</text>
  </view>

  <view class="tabs">
    <text class="tab {{tab===0?'active':''}}" bindtap="switchTab" data-idx="0">团购券</text>
    <text class="tab {{tab===1?'active':''}}" bindtap="switchTab" data-idx="1">外卖菜单</text>
    <text class="tab {{tab===2?'active':''}}" bindtap="switchTab" data-idx="2">探店笔记</text>
  </view>

  <view wx:if="{{tab===0}}" class="sec">
    <view class="v-card" wx:for="{{vouchers}}" wx:key="id" bindtap="buyVoucher" data-item="{{item}}">
      <view class="v-price">¥{{item.payValue}}</view>
      <view class="v-info"><text class="v-title">{{item.title}}</text><text class="v-desc">{{item.rule}}</text></view>
      <button class="v-btn {{item.type===1?'seckill':''}}" size="mini">{{item.type===1?'⚡秒杀':'购买'}}</button>
    </view>
  </view>

  <view wx:if="{{tab===1}}" class="sec">
    <block wx:for="{{menu}}" wx:key="name">
      <text class="cat-title">{{item.name}}</text>
      <view class="dish-item" wx:for="{{item.dishes}}" wx:key="id" wx:for-item="d">
        <view class="d-img"><text>{{d.icon}}</text></view>
        <view class="d-info"><text class="d-name">{{d.name}}</text><text class="d-price">¥{{d.price}}</text></view>
        <button class="add-btn" bindtap="addCart" data-item="{{d}}">+</button>
      </view>
    </block>
  </view>

  <view wx:if="{{tab===2}}" class="sec">
    <view class="note" wx:for="{{notes}}" wx:key="id">
      <view class="note-hd"><text class="note-user">{{item.userName}}</text><text class="note-time">{{item.time}}</text></view>
      <text class="note-content">{{item.content}}</text>
    </view>
  </view>

  <!-- 外卖菜单购物车栏 -->
  <view class="cart-bar" wx:if="{{tab===1 && cartCount>0}}" bindtap="showCartPopup">
    <view class="cb-left">
      <view class="cb-icon">🛒<text class="cb-badge">{{cartCount}}</text></view>
      <text class="cb-total">¥{{cartTotal}}</text>
    </view>
    <view class="cb-btn">去结算</view>
  </view>

  <!-- 购物车弹窗 -->
  <view wx:if="{{showCart}}" class="mask" bindtap="hideCartPopup">
    <view class="cart-popup" catchtap>
      <view class="cp-title">🛒 已选商品<text class="cp-clear" bindtap="clearCart">清空</text></view>
      <view class="cp-list">
        <view class="cp-item" wx:for="{{cartItems}}" wx:key="dishId">
          <text class="cp-name">{{item.name}}</text>
          <view class="cp-qty"><text class="cp-minus" bindtap="cartMinus" data-id="{{item.dishId}}">−</text><text class="cp-num">{{item.number}}</text><text class="cp-plus" bindtap="cartPlus" data-id="{{item.dishId}}">+</text></view>
          <text class="cp-price">¥{{item.showPrice}}</text>
        </view>
      </view>
      <view wx:if="{{!cartItems.length}}" class="cp-empty">购物车为空</view>
      <view class="cp-bottom">
        <text class="cp-total">合计 ¥{{cartTotal}}</text>
        <view class="cp-actions">
          <button class="cp-back" bindtap="hideCartPopup">继续点餐</button>
          <button class="cp-checkout" bindtap="goCart">去结算</button>
        </view>
      </view>
    </view>
  </view>
</view>
