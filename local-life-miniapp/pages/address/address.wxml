<view class="page">
  <view class="header"><text class="back" bindtap="goBack">←</text><text class="title">📍 收货地址</text><text class="add" bindtap="editAddr" data-id="">+ 新增</text></view>
  <view class="addr-card {{item.isDefault?'default':''}}" wx:for="{{addresses}}" wx:key="id">
    <view class="addr-hd"><text class="name">{{item.consignee}}</text><text class="phone">{{item.phone}}</text><text class="default-tag" wx:if="{{item.isDefault}}">默认</text></view>
    <text class="addr-detail">{{item.province}}{{item.city}}{{item.district}} {{item.detail}}</text>
    <view class="addr-actions">
      <text class="act" bindtap="editAddr" data-id="{{item.id}}">✏️ 编辑</text>
      <text class="act" wx:if="{{!item.isDefault}}" bindtap="setDefault" data-id="{{item.id}}">设为默认</text>
      <text class="act del" bindtap="delAddr" data-id="{{item.id}}">🗑 删除</text>
    </view>
  </view>
  <view wx:if="{{showForm}}" class="mask" bindtap="hideForm">
    <view class="panel" catchtap>
      <text class="f-title">{{editId?'编辑地址':'新增地址'}}</text>
      <input class="f-input" value="{{form.consignee}}" placeholder="收货人" bindinput="onField" data-field="consignee" />
      <input class="f-input" value="{{form.phone}}" placeholder="手机号" bindinput="onField" data-field="phone" />
      <input class="f-input" value="{{form.detail}}" placeholder="详细地址" bindinput="onField" data-field="detail" />
      <input class="f-input" value="{{form.label}}" placeholder="标签（家/公司等）" bindinput="onField" data-field="label" />
      <view class="f-actions"><button class="f-cancel" bindtap="hideForm">取消</button><button class="f-submit" bindtap="saveAddr">保存</button></view>
    </view>
  </view>
</view>
