.page{background:#F8F9FA;min-height:100vh}
.header{display:flex;align-items:center;padding:14px 16px;background:#fff;border-bottom:1px solid #f0f0f0}.back{font-size:18px;margin-right:8px;cursor:pointer}.title{flex:1;font-size:17px;font-weight:600}.add{color:#E8702A;font-size:13px;cursor:pointer}
.addr-card{background:#fff;margin:8px 16px 0;padding:14px;border-radius:12px;box-shadow:0 1px 4px rgba(0,0,0,.04)}.addr-card.default{border-left:3px solid #E8702A}.addr-hd{display:flex;align-items:center;gap:8px;margin-bottom:8px}.name{font-size:15px;font-weight:600}.phone{font-size:12px;color:#999}.default-tag{background:#FFF3EB;color:#E8702A;font-size:10px;padding:2px 8px;border-radius:4px}.addr-detail{display:block;font-size:13px;color:#666;line-height:1.5}.addr-actions{display:flex;gap:14px;margin-top:8px}.act{font-size:11px;color:#E8702A}.act.del{color:#bbb}
.form-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);display:flex;align-items:flex-end;z-index:200}.form-panel{background:#fff;width:100%;max-width:414px;margin:0 auto;border-radius:16px 16px 0 0;padding:20px 16px}.f-title{display:block;font-size:17px;font-weight:600;margin-bottom:16px}.f-input{display:block;width:100%;background:#F5F6F8;border:none;border-radius:8px;padding:10px 12px;font-size:14px;margin-bottom:10px;outline:none}.f-actions{display:flex;gap:8px}.f-cancel,.f-submit{flex:1;padding:10px;border-radius:22px;font-size:14px}.f-cancel{border:1px solid #ddd;background:#fff;color:#666}.f-submit{background:#E8702A;color:#fff;border:none}
