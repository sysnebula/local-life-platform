.header{display:flex;align-items:center;padding:12px 14px;background:#fff;border-bottom:1px solid #eee}.back{font-size:18px;margin-right:8px}.title{flex:1;font-size:16px;font-weight:600}.add{color:#FF6B35;font-size:13px}
.addr-card{background:#fff;margin:6px 0;padding:12px 14px}.addr-card.default{border-left:3px solid #FF6B35}.addr-hd{display:flex;align-items:center;gap:6px;margin-bottom:6px}.name{font-size:14px;font-weight:600}.phone{font-size:12px;color:#999}.default-tag{background:#FFF3E0;color:#FF6B35;font-size:10px;padding:1px 6px;border-radius:4px}.addr-detail{display:block;font-size:12px;color:#666}.addr-actions{display:flex;gap:12px;margin-top:8px}.act{font-size:11px;color:#FF6B35}.act.del{color:#999}
.mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);display:flex;align-items:flex-end;z-index:200}.panel{background:#fff;width:100%;border-radius:16px 16px 0 0;padding:16px}.f-title{display:block;font-size:16px;font-weight:600;margin-bottom:12px}.f-input{display:block;width:100%;background:#f5f5f5;border-radius:8px;padding:8px 12px;font-size:13px;margin-bottom:8px}.f-actions{display:flex;gap:8px}.f-cancel,.f-submit{flex:1;padding:8px;border-radius:20px;font-size:13px}.f-cancel{border:1px solid #ddd;background:#fff;color:#666}.f-submit{background:#FF6B35;color:#fff;border:none}
