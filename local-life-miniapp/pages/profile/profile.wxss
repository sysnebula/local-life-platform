.profile-hd{background:linear-gradient(135deg,#FF6B35,#F7931E);color:#fff;text-align:center;padding:24px 16px}.avatar{width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,.3);margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-size:28px}.nickname{display:block;font-size:17px;font-weight:600}.uid{display:block;font-size:11px;opacity:.8;margin-top:2px}.stats{display:flex;justify-content:center;gap:28px;margin-top:12px}.stat{text-align:center}.num{display:block;font-size:17px;font-weight:700}.label{font-size:10px;opacity:.8}
.menu{background:#fff;margin:6px 0;padding:0 14px}.menu-item{display:flex;align-items:center;gap:10px;padding:14px 0;border-bottom:1px solid #f5f5f5;font-size:14px}.icon{font-size:18px}.arrow{margin-left:auto;color:#ccc}.logout-wrap{padding:16px}.logout-btn{width:100%;padding:10px;border-radius:24px;border:1px solid #ddd;background:#fff;color:#999;font-size:14px}
