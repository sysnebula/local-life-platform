.page{min-height:100vh;background:#f5f5f5}
.profile-hd{background:linear-gradient(135deg,#FF6B35,#F7931E);padding:30px 16px 24px;color:#fff;text-align:center}
.avatar{width:68px;height:68px;border-radius:50%;background:rgba(255,255,255,.3);margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:30px;border:3px solid rgba(255,255,255,.5);overflow:hidden}
.nickname{display:block;font-size:18px;font-weight:600}.uid{display:block;font-size:12px;opacity:.8;margin-top:4px}
.stats{display:flex;justify-content:center;gap:30px;margin-top:14px}.stat{text-align:center}.num{display:block;font-size:18px;font-weight:700}.label{display:block;font-size:11px;opacity:.8;margin-top:2px}
.menu{background:#fff;margin:8px 0}
.menu-item{display:flex;align-items:center;gap:10px;padding:14px 16px;border-bottom:1px solid #f5f5f5;font-size:14px;color:#333}.menu-item:last-child{border-bottom:none}.icon{font-size:18px}.arrow{color:#ccc;font-size:16px;margin-left:auto}
.logout-wrap{padding:16px}.logout-btn{width:100%;padding:10px;border-radius:24px;border:1px solid #ddd;background:#fff;color:#999;font-size:14px}
.login-card{background:#fff;margin:60px 20px 0;padding:28px 20px;border-radius:12px;text-align:center}
.login-logo{font-size:48px;margin-bottom:8px}.login-title{display:block;font-size:20px;font-weight:700;color:#333}.login-sub{display:block;font-size:13px;color:#999;margin-top:4px;margin-bottom:20px}
.login-form{text-align:left}
.login-input{width:100%;background:#f5f5f5;border:none;border-radius:8px;padding:12px;font-size:14px;margin-bottom:12px}
.code-row{display:flex;gap:8px}.code{flex:1}
.send-btn{width:110px;background:#fff;border:1px solid #FF6B35;color:#FF6B35;border-radius:8px;font-size:12px;padding:10px 0;white-space:nowrap;flex-shrink:0}
.login-submit{width:100%;background:linear-gradient(135deg,#FF6B35,#F7931E);color:#fff;border:none;border-radius:24px;padding:12px;font-size:15px;font-weight:600;margin-top:16px}
.login-hint{display:block;font-size:11px;color:#ccc;margin-top:12px}
