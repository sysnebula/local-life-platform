<view class="page">
  <view class="tabs">
    <text class="tab {{tab==='all'?'active':''}}" bindtap="onTabChange" data-tab="all">全部</text>
    <text class="tab {{tab==='doing'?'active':''}}" bindtap="onTabChange" data-tab="doing">进行中</text>
    <text class="tab {{tab==='done'?'active':''}}" bindtap="onTabChange" data-tab="done">已完成</text>
  </view>
  <view class="order-card" wx:for="{{filteredOrders}}" wx:key="id">
    <view class="o-header"><text class="o-shop">{{item.shopName}}</text><text class="o-type {{item.type}}">{{item.type==='voucher'?'团购券':'外卖'}}</text></view>
    <text class="o-status {{item.status<=1?'doing':''}}{{item.status===3?'done':''}}{{item.status===4?'cancel':''}}">{{item.statusText}}</text>
    <view class="o-items"><view class="o-item" wx:for="{{item.items}}" wx:key="name" wx:for-item="oi"><text>{{oi.name}} ×{{oi.number}}</text><text>¥{{oi.price}}</text></view></view>
    <view class="o-total"><text>实付：</text><text class="total-price">¥{{item.amount}}</text></view>
    <view class="o-actions">
      <button wx:if="{{item.status<=1}}" class="btn danger" bindtap="cancel" data-id="{{item.id}}">取消订单</button>
      <button wx:if="{{item.status===1}}" class="btn primary" bindtap="remind">催单</button>
      <button wx:if="{{item.status===3}}" class="btn" bindtap="reorder" data-items="{{item.items}}">再来一单</button>
    </view>
  </view>
</view>
