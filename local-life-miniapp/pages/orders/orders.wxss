.tabs{display:flex;background:#fff;padding:0 14px;gap:16px;border-bottom:1px solid #eee}.tab{font-size:13px;color:#666;padding:10px 0}.tab.active{color:#FF6B35;border-bottom:2px solid #FF6B35}
.order-card{background:#fff;margin:6px 0;padding:12px 14px}.o-header{display:flex;justify-content:space-between;margin-bottom:6px}.o-shop{font-size:14px;font-weight:600}.o-type{padding:1px 6px;border-radius:4px;font-size:10px}.o-type.voucher{background:#FFF3E0;color:#FF6B35}.o-type.takeout{background:#E8F5E9;color:#388E3C}
.o-status{font-size:12px}.doing{color:#FF9800}.done{color:#4CAF50}.cancel{color:#999}
.o-items{margin:6px 0}.o-item{display:flex;justify-content:space-between;font-size:12px;color:#555;padding:2px 0}
.o-total{display:flex;justify-content:space-between;padding-top:6px;border-top:1px solid #f0f0f0;font-size:14px;font-weight:600}.total-price{color:#FF6B35}
.o-actions{display:flex;gap:6px;justify-content:flex-end;margin-top:8px}.btn{padding:4px 12px;border-radius:12px;font-size:11px;border:1px solid #ddd;background:#fff;color:#666}.btn.primary{background:#FF6B35;color:#fff;border-color:#FF6B35}.btn.danger{color:#F44336;border-color:#F44336}
