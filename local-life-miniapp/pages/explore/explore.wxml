<view class="page">
  <view class="header"><text class="title">📝 探店笔记</text><button class="write-btn" bindtap="startWrite">+ 写笔记</button></view>

  <!-- 笔记列表 -->
  <view class="note-card" wx:for="{{notes}}" wx:key="id">
    <view class="note-hd">
      <view class="avatar" style="background:{{item.color||'#FF6B35'}}">{{item.userName[0]}}</view>
      <view class="note-user"><text class="user-name">{{item.userName}}</text><text class="shop-tag">📍 {{item.shopName}}</text></view>
      <text class="time">{{item.time}}</text>
    </view>
    <text class="note-title">{{item.title}}</text>
    <text class="note-content">{{item.content}}</text>
  </view>

  <!-- 步骤1: 选订单 -->
  <view wx:if="{{showOrderPicker}}" class="mask" bindtap="hideOrderPicker">
    <view class="panel" catchtap>
      <text class="p-title">📋 选择一笔消费记录</text>
      <view wx:if="{{orders.length===0}}">
        <view class="empty"><text>暂无已完成订单</text></view>
      </view>
      <view class="order-list" wx:if="{{orders.length>0}}">
        <view class="order-row" wx:for="{{orders}}" wx:key="id" bindtap="selectOrder" data-id="{{item.id}}" data-type="{{item.type==='takeout'?1:0}}" data-shop="{{item.shopId}}" data-shop-name="{{item.shopName}}">
          <text class="or-icon">{{item.type==='takeout'?'🛵':'🎫'}}</text>
          <view class="or-info">
            <text class="or-shop">{{item.shopName}}</text>
            <text class="or-detail">{{item.type==='takeout'?'外卖订单':'团购券'}} · ¥{{item.amount}}</text>
          </view>
          <text class="or-arrow">›</text>
        </view>
      </view>
      <view class="p-actions"><button class="p-cancel" bindtap="hideOrderPicker">取消</button></view>
    </view>
  </view>

  <!-- 步骤2: 写笔记 -->
  <view wx:if="{{showForm}}" class="mask" bindtap="hideForm">
    <view class="panel" catchtap>
      <text class="p-title">✍️ 发布探店笔记</text>
      <view class="linked-order">关联: {{selectedOrder.shopName}} · {{selectedOrder.type==='takeout'?'外卖':'团购券'}}</view>
      <input class="p-input" placeholder="笔记标题" value="{{form.title}}" bindinput="onTitle" />
      <textarea class="p-textarea" placeholder="分享你的探店体验..." value="{{form.content}}" bindinput="onContent" />
      <view class="p-actions"><button class="p-cancel" bindtap="hideForm">取消</button><button class="p-submit" bindtap="publish">发布</button></view>
    </view>
  </view>
</view>
