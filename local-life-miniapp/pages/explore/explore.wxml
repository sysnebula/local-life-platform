<view class="page">
  <view class="header"><text class="title">📝 探店笔记</text><button class="write-btn" bindtap="showPublish">+ 写笔记</button></view>
  <view class="note-card" wx:for="{{notes}}" wx:key="id">
    <view class="note-hd"><view class="avatar" style="background:{{item.color}}">{{item.userName[0]}}</view><view class="note-user"><text class="user-name">{{item.userName}}</text><text class="shop-tag">📍 {{item.shopName}}</text></view><text class="time">{{item.time}}</text></view>
    <text class="note-title">{{item.title}}</text>
    <text class="note-content">{{item.content}}</text>
  </view>
  <view wx:if="{{showPublish}}" class="mask" bindtap="hidePublish">
    <view class="panel" catchtap>
      <text class="p-title">✍️ 发布探店笔记</text>
      <input class="p-input" placeholder="关联店铺" /><input class="p-input" placeholder="笔记标题" />
      <textarea class="p-textarea" placeholder="分享你的探店体验..." />
      <view class="p-actions"><button class="p-cancel" bindtap="hidePublish">取消</button><button class="p-submit" bindtap="publish">发布</button></view>
    </view>
  </view>
</view>
