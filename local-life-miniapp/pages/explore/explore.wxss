.header{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;background:#fff}.title{font-size:16px;font-weight:600}.write-btn{background:#FF6B35;color:#fff;border:none;border-radius:16px;padding:5px 14px;font-size:12px}
.note-card{background:#fff;margin:6px 0;padding:12px 14px}.note-hd{display:flex;align-items:center;gap:8px;margin-bottom:8px}.avatar{width:34px;height:34px;border-radius:50%;color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}.note-user{flex:1}.user-name{display:block;font-size:13px;font-weight:500}.shop-tag{font-size:11px;color:#FF6B35}.time{font-size:11px;color:#ccc}.note-title{display:block;font-size:15px;font-weight:600;margin-bottom:4px}.note-content{font-size:13px;color:#555;line-height:1.6}
.mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);display:flex;align-items:flex-end;z-index:200}.panel{background:#fff;width:100%;border-radius:16px 16px 0 0;padding:16px}.p-title{display:block;font-size:16px;font-weight:600;margin-bottom:12px}.p-input,.p-textarea{display:block;width:100%;background:#f5f5f5;border-radius:8px;padding:8px 12px;font-size:13px;margin-bottom:8px}.p-textarea{height:100px}.p-actions{display:flex;gap:8px}.p-cancel,.p-submit{flex:1;padding:8px;border-radius:20px;font-size:13px}.p-cancel{border:1px solid #ddd;background:#fff;color:#666}.p-submit{background:#FF6B35;color:#fff;border:none}
